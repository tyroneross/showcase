{
  "name": "@tyroneross/showcase",
  "version": "0.1.0",
  "description": "Dev asset capture plugin for Claude Code — screenshots and video clips during development",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "showcase": "./dist/mcp/server.js"
  },
  "files": [
    "dist",
    "commands",
    "skills",
    "hooks",
    "scripts",
    ".claude-plugin",
    ".mcp.json",
    "CLAUDE.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "postinstall": "node scripts/postinstall.js || true"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": {
    "name": "Tyrone Ross"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tyroneross/showcase"
  },
  "bugs": {
    "url": "https://github.com/tyroneross/showcase/issues"
  },
  "homepage": "https://github.com/tyroneross/showcase#readme",
  "keywords": [
    "claude-code",
    "screenshots",
    "video",
    "dev-assets",
    "capture"
  ],
  "peerDependencies": {
    "playwright": "^1.58.2"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.3.0"
  }
}
